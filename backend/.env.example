# Application Configuration
PROJECT_NAME="AI Academic Operations Platform"
API_V1_STR="/api/v1"
SECRET_KEY="replace-this-with-a-very-secure-random-key-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Supabase / PostgreSQL Database Configuration
# For local Postgres, use: postgresql+asyncpg://postgres:postgres@localhost:5432/academic_ops
# For Supabase, use your project database connection string (Transaction pooler port 6543, asyncpg driver):
DATABASE_URL="postgresql+asyncpg://postgres:[YOUR-PASSWORD]@[YOUR-SUPABASE-DB-HOST]:6543/postgres"

# Supabase REST API Configuration
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# SMTP / Email Service (For OTP Delivery)
# If left empty, OTPs will be printed to the backend console for development ease
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL="noreply@university.edu"
